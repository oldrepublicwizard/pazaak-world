{
  "name": "pazaak-world",
  "version": "0.1.0",
  "private": true,
  "description": "Holowan Multiplayer Pazaak (Pazaak World): Discord bot, browser client, and engine.",
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsc -b tsconfig.workspace.json",
    "check": "tsc -b tsconfig.workspace.json --pretty false",
    "test": "node --test packages/*/dist/*.test.js",
    "check:pazaak-oauth": "node scripts/check_pazaak_oauth_readiness.mjs",
    "check:pazaak-oauth:checklist": "node scripts/check_pazaak_oauth_readiness.mjs --checklist",
    "dev:pazaak": "pnpm --filter @pazaak/pazaak-bot dev",
    "dev:pazaak-world": "pnpm --filter pazaak-world dev",
    "dev:pazaak-nakama": "pnpm --filter @pazaak/pazaak-nakama build && docker compose -f infra/nakama/docker-compose.yml up",
    "build:pazaak-nakama": "pnpm --filter @pazaak/pazaak-nakama build"
  },
  "devDependencies": {
    "@types/node": "^24.12.3",
    "tsx": "^4.20.6",
    "typescript": "~6.0.2"
  }
}
