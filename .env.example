# Holowan Multiplayer Pazaak — local secrets (do not commit real values)

# Shared persistence (optional; JSON files under PAZAAK_DATA_DIR work without Postgres)
DATABASE_URL=

# Discord application for the Pazaak bot / Activity
PAZAAK_DISCORD_APP_ID=
PAZAAK_DISCORD_PUBLIC_KEY=
PAZAAK_DISCORD_BOT_TOKEN=
PAZAAK_DISCORD_CLIENT_SECRET=
PAZAAK_DISCORD_GUILD_ID=

PAZAAK_DATA_DIR=data/pazaak-bot
PAZAAK_STARTING_CREDITS=1000
PAZAAK_DAILY_BONUS=200
PAZAAK_DAILY_COOLDOWN_MS=86400000
PAZAAK_TURN_TIMEOUT_MS=300000
PAZAAK_API_PORT=4001

# Public SPA origins (Holowan-owned). Discord Activity / OAuth *post-login* return here.
PAZAAK_ACTIVITY_URL=https://oldrepublicwizard.github.io/pazaak-world/
PAZAAK_PUBLIC_WEB_ORIGIN=https://oldrepublicwizard.github.io/pazaak-world/
PAZAAK_ALLOW_DEV_AUTH=true

# Holowan: guests may play without uploading chitin.key (local AI + online when API live).
# Set to 1 only if you intentionally re-gate Match/Lobby on ownership proof.
CARDWORLD_REQUIRE_CHITIN_KEY=0

# Standalone OAuth (browser sign-in)
# Callbacks MUST hit the API host (local bot or Cloudflare Worker) — NEVER github.io
# (Pages has no /api reverse proxy). After token issue, the API redirects to PUBLIC_WEB_ORIGIN.
PAZAAK_OAUTH_DISCORD_CLIENT_ID=
PAZAAK_OAUTH_DISCORD_CLIENT_SECRET=
PAZAAK_OAUTH_DISCORD_CALLBACK_URL=http://127.0.0.1:4001/api/auth/oauth/discord/callback

PAZAAK_OAUTH_GOOGLE_CLIENT_ID=
PAZAAK_OAUTH_GOOGLE_CLIENT_SECRET=
PAZAAK_OAUTH_GOOGLE_CALLBACK_URL=http://127.0.0.1:4001/api/auth/oauth/google/callback

PAZAAK_OAUTH_GITHUB_CLIENT_ID=
PAZAAK_OAUTH_GITHUB_CLIENT_SECRET=
PAZAAK_OAUTH_GITHUB_CALLBACK_URL=http://127.0.0.1:4001/api/auth/oauth/github/callback

# Vite client (apps/pazaak-world) — comma-separated API origins for multiplayer
# Local: VITE_API_BASES=http://127.0.0.1:4001
# Pages build: set GitHub Actions variable PAZAAK_API_BASES to the Worker/bot HTTPS origin
# VITE_API_BASES=
